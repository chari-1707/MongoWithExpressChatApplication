<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Whatsapp</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <div class="header">
        <h3>All Chats</h3>

        <form method="GET" action="/chats/new">
            <button class="new-chat-btn" type="submit">
                + New Chat
            </button>
        </form>
    </div>

    <% for (let chat of chats) { %>

        <div class="chat">

            <div class="chat-top">
                <p><strong>From:</strong> <%= chat.from %></p>

                <span class="date">
                    <%= chat.created_at.toLocaleString() %>
                </span>
            </div>

            <div class="msg">
                <p><%= chat.message %></p>
            </div>

            <div class="actions">

                <form action="/chats/<%= chat._id %>/edit" method="GET">
                    <button class="edit-btn" type="submit">✏️ Edit</button>
                </form>

                <form action="/chats/<%= chat._id %>?_method=DELETE" method="POST">
                    <button class="delete-btn" type="submit">
                        🗑️ Delete
                    </button>
                </form>

            </div>

            <p><strong>To:</strong> <%= chat.to %></p>

        </div>

    <% } %>

</body>

</html>