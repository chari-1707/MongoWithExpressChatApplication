<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Chat</title>
    <link rel="stylesheet" href="/style2.css">
</head>

<body>

    <div class="page">

        <div class="form-container">

            <h1>Create New Chat</h1>
            <p class="subtitle">Start a new conversation by filling in the details below.</p>

            <form method="post" action="/chats" method="POST">

                <div class="form-group">
                    <label for="from">From</label>
                    <input type="text" id="from" name="from" placeholder="Enter sender name" required>
                </div>

                <div class="form-group">
                    <label for="to">To</label>
                    <input type="text" id="to" name="to" placeholder="Enter receiver name" required>
                </div>

                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" rows="6" placeholder="Write your message here..."
                        required></textarea>
                </div>

                <button type="submit">
                    Send Message
                </button>

            </form>

        </div>

    </div>

</body>

</html>